{
  "name": "the-production-agent-skill",
  "version": "0.2.0",
  "description": "A production-grade human language skill guide framework for AI coding agents.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "keywords": [
    "ai-agent",
    "coding-agent",
    "agent-rules",
    "software-engineering",
    "production",
    "framework"
  ],
  "bin": {
    "the-production-agent-skill": "bin/the-production-agent-skill.mjs"
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "instructions.md",
    "backend/",
    "frontend/",
    "mobile/",
    "computer-use/",
    "arsenals/",
    "docs/",
    "scripts/",
    "bin/",
    "test/"
  ],
  "scripts": {
    "pack": "npm pack --dry-run",
    "publish:dry-run": "npm publish --dry-run",
    "test": "node --test test/*.test.mjs",
    "security:supply-chain": "node scripts/supply-chain-audit.mjs",
    "security:supply-chain:fix": "node scripts/supply-chain-audit.mjs --fix",
    "validate": "node --check bin/the-production-agent-skill.mjs && node bin/the-production-agent-skill.mjs doctor --package-root . --package-only && npm test"
  },
  "engines": {
    "node": ">=18"
  }
}
